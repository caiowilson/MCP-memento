{
  "name": "memento-mcp-vscode",
  "displayName": "Memento MCP",
  "description": "Companion VS Code extension that installs the memento-mcp server binary and helps generate MCP config snippets.",
  "version": "0.0.1",
  "publisher": "caiowilson",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:mementoMcp.installServer",
    "onCommand:mementoMcp.configureMcp",
    "onCommand:mementoMcp.openOrCreateMcpConfig",
    "onCommand:mementoMcp.openMcpConfigSnippet",
    "onCommand:mementoMcp.copyMcpConfigSnippet"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mementoMcp.installServer",
        "title": "Memento MCP: Install Server Binary"
      },
      {
        "command": "mementoMcp.configureMcp",
        "title": "Memento MCP: Configure MCP (Workspace/Global)"
      },
      {
        "command": "mementoMcp.openOrCreateMcpConfig",
        "title": "Memento MCP: Configure MCP (Workspace)"
      },
      {
        "command": "mementoMcp.openMcpConfigSnippet",
        "title": "Memento MCP: Open MCP Config Snippet"
      },
      {
        "command": "mementoMcp.copyMcpConfigSnippet",
        "title": "Memento MCP: Copy MCP Config Snippet"
      }
    ],
    "configuration": {
      "title": "Memento MCP",
      "properties": {
        "mementoMcp.githubRepo": {
          "type": "string",
          "default": "caiowilson/MCP-memento",
          "description": "GitHub repo used to download server binaries from Releases (owner/name)."
        },
        "mementoMcp.releaseTag": {
          "type": "string",
          "default": "server/latest",
          "description": "GitHub release tag to download (e.g. 'server/latest' or 'latest')."
        },
        "mementoMcp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Optional override path to the memento-mcp binary."
        },
        "mementoMcp.preferWorkspaceBinary": {
          "type": "boolean",
          "default": true,
          "description": "If ${workspaceFolder}/bin/memento-mcp exists, prefer it for the generated snippet."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "mementoMcp.installServer",
          "group": "Memento MCP"
        },
        {
          "command": "mementoMcp.configureMcp",
          "group": "Memento MCP"
        },
        {
          "command": "mementoMcp.openOrCreateMcpConfig",
          "group": "Memento MCP"
        },
        {
          "command": "mementoMcp.openMcpConfigSnippet",
          "group": "Memento MCP"
        },
        {
          "command": "mementoMcp.copyMcpConfigSnippet",
          "group": "Memento MCP"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.5.0"
  }
}
